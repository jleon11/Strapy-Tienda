{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "maxLength": 80,
      "required": true,
      "unique": true
    },
    "precio": {
      "type": "integer"
    },
    "precioAnteriorValor": {
      "type": "integer"
    },
    "stock": {
      "type": "integer"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "marca": {
      "type": "string"
    },
    "codigo": {
      "type": "string"
    },
    "destacado": {
      "type": "boolean"
    },
    "activo": {
      "type": "boolean"
    },
    "descripcion": {
      "type": "text"
    },
    "informacionGeneral": {
      "type": "text"
    },
    "mostrarEnlaSeccion": {
      "type": "enumeration",
      "enum": [
        "PROMO-DEL-MES",
        "LOS-MAS-BUSCADOS",
        "LOS-MAS-VENDIDOS",
        "PRODUCTOS-NUEVOS"
      ]
    },
    "sub_categoria": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::sub-categoria.sub-categoria",
      "required": true
    }
  }
}
