{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string"
    },
    "descripcion": {
      "type": "blocks"
    },
    "precio": {
      "type": "decimal"
    },
    "precioAnteriorValor": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "marca": {
      "type": "string"
    },
    "codigo": {
      "type": "string"
    },
    "destacado": {
      "type": "boolean"
    },
    "activo": {
      "type": "boolean"
    },
    "informacionGeneral": {
      "type": "blocks"
    },
    "categoria": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::categoria.categoria"
    }
  }
}
